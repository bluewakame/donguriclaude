    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.3",
    "autoprefixer": "^10.0.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "jsqr": "^1.4.0",
    "leaflet": "^1.9.4",
    "next": "14.2.5",
    "next-auth": "^5.0.0-beta.19",
    "postcss": "^8",
    "prisma": "^5.16.1",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.4.0",
