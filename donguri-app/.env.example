# ============================================================
# どんぐりアプリ 環境変数サンプル
# このファイルを .env.local にコピーして値を設定してください
# cp .env.example .env.local
# ============================================================

# Supabase（データベース）
# Supabase: https://supabase.com でプロジェクトを作成
# Settings > Database > Connection String (URI) から取得
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# NextAuth.js
# openssl rand -base64 32 で生成したランダム文字列
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth（Googleログイン用）
# https://console.cloud.google.com/ でOAuth 2.0クライアントIDを作成
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Maps API
# https://console.cloud.google.com/ でMaps JavaScript APIを有効化
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Web Push（プッシュ通知用）
# npx web-push generate-vapid-keys で生成
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# Vercel Cron（本番環境のみ）
# Vercelのダッシュボードで設定
CRON_SECRET="your-cron-secret"
